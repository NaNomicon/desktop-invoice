{
  "$schema": "https://v2.tauri.app/schemas/2.0/schema.json",
  "productName": "XPress Billing",
  "version": "0.1.0",
  "identifier": "com.ramma.xpress",
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "windows": [
      {
        "title": "XPress Billing",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "sql": {
      "preload": ["sqlite:xpress.db"]
    }
  }
}