<?xml version="1.0"?>
<configuration>
    <configSections>
    </configSections>

    <!-- Enable JIT debugging for unhandled exceptions -->
    <system.diagnostics>
        <assert assertuienabled="true" logfilename="C:\XPress\jit_debug.log"/>
    </system.diagnostics>

    <connectionStrings>
        <add name="XPress.My.MySettings.XPressDBConnectionString" connectionString="Data Source=.\SQLEXPRESS;Initial Catalog=XPressDB;User ID=abc;Password=12345;TrustServerCertificate=True;" providerName="System.Data.SqlClient"/>
    </connectionStrings>
    <startup>
      
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.0,Profile=Client"/></startup>
</configuration>
